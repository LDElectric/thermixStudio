<Window x:Class="ThermixStudio.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThermixStudio.App"
        mc:Ignorable="d"
        Title="Sobre o Thermix Studio"
        Width="620"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        Foreground="#E6E6EF">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#161626" BorderBrush="#2A2A42" BorderThickness="1" CornerRadius="14" Padding="24">
            <StackPanel>
                <TextBlock Text="{x:Static local:AppInfo.ProductName}" FontSize="28" FontWeight="SemiBold" Foreground="#FF6600"/>
                <TextBlock Text="{x:Static local:AppInfo.DisplayVersion}" FontSize="15" Margin="0,6,0,0" Foreground="#BFC3D9"/>
                <TextBlock Text="{x:Static local:AppInfo.AboutText}" TextWrapping="Wrap" Margin="0,18,0,0" FontSize="14"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,16,0,0" Background="#202036" BorderBrush="#2A2A42" BorderThickness="1" CornerRadius="14" Padding="18">
            <StackPanel>
                <TextBlock Text="Versão e texto institucional ficam centralizados em AppInfo.cs." FontSize="12" Margin="0,16,0,0" Foreground="#9AA0BE" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Fechar" Width="110" Height="34" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
