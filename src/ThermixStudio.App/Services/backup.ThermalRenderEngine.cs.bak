    private static ThermalPaletteLUT BuildLut(ThermalPalette palette)
    {
        // Use camera-extracted LUTs for FLIR standard palettes (exact colors from EXIF, YCbCr→RGB BT.601)
        if (palette == ThermalPalette.Iron)      return new ThermalPaletteLUT(_flirIronLut,      "Iron");
        if (palette == ThermalPalette.Grayscale) return new ThermalPaletteLUT(_flirGrayscaleLut, "Grayscale");
        if (palette == ThermalPalette.Rainbow)   return new ThermalPaletteLUT(_flirRainbowLut,   "Rainbow");

        // Mathematical fallback for Hotmetal / Arctic / Thermal
        var lut = new byte[256 * 4];
        for (var i = 0; i < 256; i++)
        {
            var n = i / 255.0;
            var color = palette switch
            {
                ThermalPalette.Hotmetal => MapHotmetal(n),
                ThermalPalette.Arctic   => MapArctic(n),
                ThermalPalette.Thermal  => MapThermal(n),
                _                       => MapIron(n)
            };
            var baseIdx = i * 4;
            lut[baseIdx]     = color.B;
            lut[baseIdx + 1] = color.G;
            lut[baseIdx + 2] = color.R;
            lut[baseIdx + 3] = 255;
        }
        return new ThermalPaletteLUT(lut, palette.ToString());
    }

    private static (double min, double max) GetAbsoluteRange(ThermalImageData image)
    {
        var min = double.MaxValue;
        var max = double.MinValue;

        for (var y = 0; y < image.Height; y++)
            for (var x = 0; x < image.Width; x++)
            {
                var t = image.Temperatures[y, x];
                if (t < min) min = t;
                if (t > max) max = t;
            }

        if (!double.IsFinite(min) || !double.IsFinite(max) || min >= max)
            return (0, 1);

        return (min, max);
    }

    private static Color MapGrayscale(double n)
    {
        var v = (byte)(n * 255);
        return Color.FromRgb(v, v, v);
    }

    private static Color LerpStops((double T, int R, int G, int B)[] stops, double n)
    {
        for (var i = 1; i < stops.Length; i++)
        {
            if (n <= stops[i].T)
            {
                var span = stops[i].T - stops[i - 1].T;
                var f = span <= 0 ? 0 : (n - stops[i - 1].T) / span;
                return Color.FromRgb(
                    (byte)(stops[i - 1].R + f * (stops[i].R - stops[i - 1].R)),
                    (byte)(stops[i - 1].G + f * (stops[i].G - stops[i - 1].G)),
                    (byte)(stops[i - 1].B + f * (stops[i].B - stops[i - 1].B)));
            }
        }
        var last = stops[stops.Length - 1];
        return Color.FromRgb((byte)last.R, (byte)last.G, (byte)last.B);
    }

    // FLIR Iron (Ironbow) — calibrado por câmera FLIR E-series
    private static Color MapIron(double n)
    {
        (double T, int R, int G, int B)[] stops =
        {
            (0.00,   0,   0,   0),
            (0.10,   5,   0,  40),
            (0.20,  25,   0,  90),
            (0.30,  75,   0, 110),
            (0.40, 130,   0,  75),
            (0.50, 175,  15,   5),
            (0.60, 225,  70,   0),
            (0.70, 255, 150,   0),
            (0.80, 255, 230,  25),
            (0.92, 255, 255, 190),
            (1.00, 255, 255, 255),
        };
        return LerpStops(stops, n);
    }

    // FLIR Rainbow — calibrado por câmera FLIR E-series
    private static Color MapRainbow(double n)
    {
        (double T, int R, int G, int B)[] stops =
        {
            (0.00,   0,   0,  50),
            (0.12,   0,   0, 160),
            (0.25,   0,  60, 210),
            (0.38,   0, 180, 215),
            (0.50,   0, 215, 120),
            (0.60,  50, 220,   0),
            (0.70, 200, 225,   0),
            (0.80, 255, 140,   0),
            (0.90, 245,  35,   0),
            (1.00, 190,   0,   0),
        };
        return LerpStops(stops, n);
    }

    // Hot Metal: preto → vermelho → laranja → amarelo → branco
    private static Color MapHotmetal(double n)
    {
        (double T, int R, int G, int B)[] stops =
        {
            (0.00,   0,   0,   0),
            (0.25, 128,   0,   0),
            (0.50, 255,   0,   0),
            (0.75, 255, 128,   0),
            (1.00, 255, 255, 255),
        };
        return LerpStops(stops, n);
    }

    // Arctic: azuis frios → ciano → branco
    private static Color MapArctic(double n)
    {
        (double T, int R, int G, int B)[] stops =
        {
            (0.00,   0,   0,  40),
            (0.25,   0,  80, 160),
            (0.50,   0, 160, 200),
            (0.75, 100, 200, 255),
            (1.00, 255, 255, 255),
        };
        return LerpStops(stops, n);
    }

    // Thermal: azul → ciano → amarelo → laranja → vermelho
    private static Color MapThermal(double n)
    {
        (double T, int R, int G, int B)[] stops =
        {
            (0.00,   0,   0, 255),
            (0.25,   0, 128, 255),
            (0.40,   0, 255, 255),
            (0.60, 255, 255,   0),
            (0.80, 255, 128,   0),
            (1.00, 255,   0,   0),
        };
        return LerpStops(stops, n);
    }
}
