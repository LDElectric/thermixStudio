using System.Windows.Media;
using ThermixStudio.Core;

namespace ThermixStudio.App.Services;

/// <summary>
/// Representa uma LUT (Look-Up Table) de 256 cores pré-computada para rendering rápido.
/// </summary>
public sealed class ThermalPaletteLUT
{
    public byte[] BgraLut { get; }      // 256 × 4 bytes (BGRA) = 1024 bytes
    public string PaletteName { get; }
    public bool IsEmbedded { get; }

    public ThermalPaletteLUT(byte[] bgraLut, string paletteName, bool isEmbedded = false)
    {
        if (bgraLut.Length != 256 * 4)
            throw new ArgumentException("LUT must be exactly 1024 bytes (256 colors × 4 channels).", nameof(bgraLut));

        BgraLut = bgraLut;
        PaletteName = paletteName;
        IsEmbedded = isEmbedded;
    }
}

public sealed class ThermalRenderEngine : IThermalRenderEngine
{
    private ThermalPaletteLUT? _cachedLut;
    private ThermalPalette _cachedPaletteType;
    private ThermalPaletteLUT? _embeddedPaletteLut;

    public ThermalRenderResult Render(ThermalImageData image, ThermalRenderParameters parameters)
    {
        var width = image.Width;
        var height = image.Height;

        var (absoluteMin, absoluteMax) = GetAbsoluteRange(image);
        var appliedMin = parameters.AutoScale ? absoluteMin : parameters.LevelMinC ?? absoluteMin;
        var appliedMax = parameters.AutoScale ? absoluteMax : parameters.LevelMaxC ?? absoluteMax;

        if (appliedMax <= appliedMin)
            appliedMax = appliedMin + 0.01;

        var range = appliedMax - appliedMin;
        var pixels = new byte[width * height * 4];
        var lut = GetOrBuildLut(parameters.Palette);

        for (var y = 0; y < height; y++)
        {
            for (var x = 0; x < width; x++)
            {
                var t = image.Temperatures[y, x];
                var n = Math.Clamp((t - appliedMin) / range, 0.0, 1.0);
                var colorIdx = (int)(n * 255) * 4;

                var idx = ((y * width) + x) * 4;
                pixels[idx]     = lut.BgraLut[colorIdx];
                pixels[idx + 1] = lut.BgraLut[colorIdx + 1];
                pixels[idx + 2] = lut.BgraLut[colorIdx + 2];
                pixels[idx + 3] = 255;
            }
        }

        return new ThermalRenderResult
        {
            Width = width,
            Height = height,
            BgraPixels = pixels,
            AppliedMinC = appliedMin,
            AppliedMaxC = appliedMax
        };
    }

    /// <summary>
    /// Define a paleta FLIR embutida para renderização com fidelidade máxima à câmera.
    /// paletteData deve ser BGRA (256 × 4 bytes).
    /// Para usar a paleta embarcada, selecione ThermalPalette.Original.
    /// </summary>
    public void SetEmbeddedPalette(byte[]? paletteData)
    {
        if (paletteData is not null && paletteData.Length == 256 * 4)
            _embeddedPaletteLut = new ThermalPaletteLUT(paletteData, "Original FLIR", isEmbedded: true);
        else
            _embeddedPaletteLut = null;
    }

    private ThermalPaletteLUT GetOrBuildLut(ThermalPalette palette)
    {
        // Se usuário selecionou "Original" e temos embedded disponível, usa ela
        if (palette == ThermalPalette.Original && _embeddedPaletteLut is not null)
            return _embeddedPaletteLut;

        // Caso contrário, usa LUT hardcoded nomeada (Iron, Rainbow, etc)
        if (_cachedLut != null && _cachedPaletteType == palette)
            return _cachedLut;

        _cachedPaletteType = palette;
        _cachedLut = BuildLut(palette);
        return _cachedLut;
    }

