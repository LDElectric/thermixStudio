<Window x:Class="ThermixStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:ThermixStudio.App"
        mc:Ignorable="d"
        Title="Thermix Studio"
        MinHeight="720"
        MinWidth="1200"
        Height="840"
        Width="1440"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        KeyboardNavigation.TabNavigation="Cycle"
        KeyboardNavigation.DirectionalNavigation="Cycle"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#1A1A2E">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoLastActionCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectionCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
            <!-- Converters -->
            <local:FileNameValueConverter x:Key="FileNameConverter"/>
            <local:NullToVisibilityValueConverter x:Key="NullToVisibilityConverter"/>
            <local:CriticalityToPortugueseConverter x:Key="CriticalityToPortugueseConverter"/>
            <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <local:BooleanToVisibilityValueConverter x:Key="BooleanToVisibilityConverter"/>
            <local:ImageViewModeToPortugueseConverter x:Key="ImageViewModeToPortugueseConverter"/>
            <local:IsothermModeToPortugueseConverter x:Key="IsothermModeToPortugueseConverter"/>
            <local:AnalysisToolToPortugueseConverter x:Key="AnalysisToolToPortugueseConverter"/>
            <local:ThermalPaletteToPortugueseConverter x:Key="ThermalPaletteToPortugueseConverter"/>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Padding" Value="10,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E8EEF9"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- FLIR-style dark button -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#C8C8D8"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="1,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6600"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#FF8833"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CC5500"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent (orange) button -->
        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#FF6600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF8833"/>
        </Style>

        <!-- Panel section header -->
        <Style x:Key="PanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6600"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Property label -->
        <Style x:Key="PropLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- Property text input -->
        <Style x:Key="PropInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#D8D8E8"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="PropComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#A8A8B8"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#E8EEF9"/>
                                <Setter Property="Foreground" Value="#111111"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator vertical -->
        <Style x:Key="ToolSepStyle" TargetType="Separator">
            <Setter Property="Background" Value="#3A3A52"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="4,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu Bar -->
            <RowDefinition Height="40"/>    <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main area -->
            <RowDefinition Height="26"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ROW 0 — MENU BAR
             ═══════════════════════════════════════════════════ -->
        <Menu Grid.Row="0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <MenuItem Header="Arquivo">
                <MenuItem Header="Abrir Termograma..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Exportar Termograma..." Command="{Binding ExportIdenticalJpgCommand}"/>
                <Separator/>
                <MenuItem Header="Sair" Click="MenuItem_Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Editar">
                <MenuItem Header="Desfazer" Command="{Binding UndoLastActionCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="Remover Medição Selecionada" Command="{Binding RemoveSelectedMeasurementCommand}"/>
                <MenuItem Header="Remover" Command="{Binding RemoveSelectedThermogramCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="Ferramentas">
                <MenuItem Header="Mão (Mover)" Click="MenuItem_HandTool_Click"/>
                <MenuItem Header="Spot" Command="{Binding AddSpotCommand}"/>
                <MenuItem Header="Área" Command="{Binding AddAreaCommand}"/>
                <MenuItem Header="Círculo" Command="{Binding AddCircleCommand}"/>
                <MenuItem Header="Linha" Command="{Binding AddLineCommand}"/>
                <MenuItem Header="Diferença (2 Spots)" Command="{Binding AddDifferenceCommand}"/>
                <Separator/>
                <MenuItem Header="Ilustração: Seta" Click="MenuItem_IllustrationArrow_Click"/>
                <MenuItem Header="Ilustração: Retângulo" Click="MenuItem_IllustrationRectangle_Click"/>
                <MenuItem Header="Ilustração: Elipse" Click="MenuItem_IllustrationEllipse_Click"/>
                <MenuItem Header="Ilustração: Texto" Click="MenuItem_IllustrationText_Click"/>
                <Separator/>
                <MenuItem Header="Exportar CSV da Imagem" Command="{Binding ExportImageCsvCommand}"/>
                <MenuItem Header="Exportar CSV de Medições" Command="{Binding ExportMeasurementsCsvCommand}"/>
            </MenuItem>
            <MenuItem Header="Relatório">
                <MenuItem Header="Gerar Relatório..." Command="{Binding GenerateReportCommand}"/>
            </MenuItem>
            <MenuItem Header="Ajuda">
                <MenuItem Header="Instruções" Click="MenuItem_Instrucoes_Click"/>
                <MenuItem Header="Sobre o Thermix Studio" Click="MenuItem_About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════
             ROW 1 — TOOLBAR
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#161626" BorderBrush="#2A2A42" BorderThickness="0,0,0,1">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center" ItemHeight="32">

                    <!-- File group -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding OpenFileCommand}"
                            ToolTip="Abrir Termograma (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C2;" FontSize="13" Margin="0,0,4,0"/>
                            <TextBlock Text="Abrir"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{StaticResource ToolSepStyle}"/>

                    <!-- Measurement tools -->
                    <TextBlock Text="FERRAMENTAS:" VerticalAlignment="Center"
                               Foreground="#606080" FontSize="10" Margin="4,0,6,0" FontFamily="Segoe UI"/>

                    <ComboBox Width="150" Height="24"
                              Style="{StaticResource PropComboStyle}"
                              ItemsSource="{Binding ToolOptions}"
                              SelectedItem="{Binding ActiveTool}"
                              Margin="0,0,4,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource AnalysisToolToPortugueseConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding AddDifferenceCommand}"
                            ToolTip="Diferença entre os dois últimos spots">
                        <TextBlock Text="ΔT"/>
                    </Button>

                    <Separator Style="{StaticResource ToolSepStyle}"/>

                    <TextBlock Text="MODO DE EXIBICAO:" VerticalAlignment="Center"
                               Foreground="#606080" FontSize="10" Margin="4,0,6,0" FontFamily="Segoe UI"/>

                    <ComboBox Width="220"
                              Height="30"
                              Margin="0,0,4,0"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding ImageViewModes}"
                              SelectedItem="{Binding ImageViewMode, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Selecione o modo de imagem">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource ImageViewModeToPortugueseConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="PALETA:" VerticalAlignment="Center"
                               Foreground="#606080" FontSize="10" Margin="8,0,6,0" FontFamily="Segoe UI"/>

                    <ComboBox Width="170"
                              Height="30"
                              Margin="0,0,4,0"
                              VerticalAlignment="Center"
                              Style="{StaticResource PropComboStyle}"
                              ItemsSource="{Binding PaletteOptions}"
                              SelectedItem="{Binding SelectedPalette}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource ThermalPaletteToPortugueseConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowBlendControls, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="8,0,0,0">
                        <TextBlock Text="BLENDING:" VerticalAlignment="Center" Foreground="#606080" FontSize="10" Margin="4,0,6,0" FontFamily="Segoe UI"/>
                        <Slider Width="100" Value="{Binding BlendFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="1" Height="20" VerticalAlignment="Center" Foreground="#FF6600" Background="#2A2A42"/>
                        <TextBlock Text="{Binding BlendFactor, StringFormat='{}{0:P0}'}" Foreground="#D8D8E8" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" Width="35"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowMsxControls, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="8,0,0,0">
                        <TextBlock Text="MSX:" VerticalAlignment="Center" Foreground="#606080" FontSize="10" Margin="4,0,6,0" FontFamily="Segoe UI"/>
                        <Slider Width="100" Value="{Binding MsxStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="1" Height="20" VerticalAlignment="Center" Foreground="#FF6600" Background="#2A2A42"/>
                        <TextBlock Text="{Binding MsxStrength, StringFormat='{}{0:P0}'}" Foreground="#D8D8E8" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" Width="35"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowPipControls, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="8,0,0,0">
                        <TextBlock Text="PIP SCALE:" VerticalAlignment="Center" Foreground="#606080" FontSize="10" Margin="4,0,6,0" FontFamily="Segoe UI"/>
                        <Slider Width="100" Value="{Binding PipScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0.1" Maximum="1" Height="20" VerticalAlignment="Center" Foreground="#FF6600" Background="#2A2A42"/>
                        <TextBlock Text="{Binding PipScale, StringFormat='{}{0:P0}'}" Foreground="#D8D8E8" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" Width="35"/>
                    </StackPanel>

                </WrapPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding GenerateReportCommand}"
                        ToolTip="Gerar relatório PDF/HTML para o termograma selecionado"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4CB;" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Gerar Relatório"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 2 — MAIN AREA  [Left | Center | Right]
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL: Thermogram Library ── -->
            <Border Grid.Column="0" Background="#1E1E30" BorderBrush="#2A2A42" BorderThickness="0,0,1,0">
                <DockPanel Margin="0">
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#161626" Padding="10,8">
                        <TextBlock Text="BIBLIOTECA DE TERMOGRAMAS"
                                   Foreground="#FF6600" FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Thermogram list -->
                    <ListBox x:Name="ThermogramListBox"
                             DockPanel.Dock="Top"
                             ItemsSource="{Binding Thermograms}"
                             SelectedItem="{Binding SelectedThermogram}"
                             Background="Transparent"
                             BorderThickness="0"
                             PreviewMouseRightButtonDown="ThermogramListBox_PreviewMouseRightButtonDown"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ListBox.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Exportar Termograma..."
                                          Command="{Binding ExportIdenticalJpgCommand}"/>
                                <Separator/>
                                <MenuItem Header="Remover"
                                          Command="{Binding RemoveSelectedThermogramCommand}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#C8C8D8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A2A42"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3050"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#222238"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"
                                               Text="{Binding FilePath, Converter={StaticResource FileNameConverter}}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding CaptureAtUtc, StringFormat='{}{0:dd/MM/yy HH:mm}'}"
                                                   FontSize="10" Foreground="#7878A0"/>
                                        <TextBlock Text=" | " FontSize="10" Foreground="#4A4A62"/>
                                        <TextBlock Text="{Binding EquipmentTag}" FontSize="10" Foreground="#FF8844"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#2A2A42" HorizontalAlignment="Stretch"/>

            <!-- ── CENTER: Thermal Canvas ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Image area -->
                <Border Grid.Row="0" Background="#0B0B18" BorderBrush="#2A2A42" BorderThickness="0">
                    <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Exportar Termograma..."
                                      Command="{Binding ExportIdenticalJpgCommand}"/>
                            <Separator/>
                            <MenuItem Header="Exportar CSV da Imagem"
                                      Command="{Binding ExportImageCsvCommand}"/>
                            <MenuItem Header="Exportar CSV de Medições"
                                      Command="{Binding ExportMeasurementsCsvCommand}"/>
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid>
                        <!-- Placeholder text when no image -->
                        <TextBlock Text="Nenhum termograma selecionado&#x0A;Use Abrir para importar arquivos"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#3A3A5A" FontSize="16" TextAlignment="Center"
                                   Visibility="{Binding DisplayImage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                      Background="Transparent">
                            <Grid x:Name="ImageZoomContainer" RenderTransformOrigin="0,0">
                                <Grid.LayoutTransform>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.LayoutTransform>

                                <Image x:Name="ThermalImageControl"
                                       Source="{Binding DisplayImage}"
                                       Stretch="None"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <Canvas x:Name="OverlayCanvas"
                                        Width="{Binding ElementName=ThermalImageControl, Path=ActualWidth}"
                                        Height="{Binding ElementName=ThermalImageControl, Path=ActualHeight}"
                                        IsHitTestVisible="False"/>

                                <Canvas x:Name="InteractionCanvas"
                                        Width="{Binding ElementName=ThermalImageControl, Path=ActualWidth}"
                                        Height="{Binding ElementName=ThermalImageControl, Path=ActualHeight}"
                                        Background="Transparent"
                                        MouseLeftButtonDown="InteractionCanvas_MouseLeftButtonDown"
                                    MouseLeftButtonUp="InteractionCanvas_MouseLeftButtonUp"
                                        MouseMove="InteractionCanvas_MouseMove"
                                        MouseRightButtonDown="InteractionCanvas_MouseRightButtonDown"
                                        MouseRightButtonUp="InteractionCanvas_MouseRightButtonUp"/>
                            </Grid>
                        </ScrollViewer>


                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#111120"
                        BorderBrush="#2A2A42"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                            <CheckBox Content="Auto"
                                      IsChecked="{Binding AutoScaleEnabled}"
                                      Foreground="#D8D8E8"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <Button Content="Camera"
                                    Command="{Binding UseCameraScaleCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Padding="8,3"
                                    ToolTip="Usar a escala visual gravada pela camera"/>
                        </StackPanel>

                        <Grid Grid.Column="1" ToolTip="Temperatura minima da escala visual" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource PropInputStyle}"
                                     Text="{Binding LevelMinC, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                     HorizontalContentAlignment="Right"/>
                            <Grid Grid.Column="1" Margin="1,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <RepeatButton Grid.Row="0" Content="▲" Command="{Binding IncrementLevelMinCommand}" FontSize="6" Padding="0" Background="#2A2A3E" Foreground="#C8C8D8" BorderThickness="0" Margin="0,2,0,1" Delay="300" Interval="50"/>
                                <RepeatButton Grid.Row="1" Content="▼" Command="{Binding DecrementLevelMinCommand}" FontSize="6" Padding="0" Background="#2A2A3E" Foreground="#C8C8D8" BorderThickness="0" Margin="0,1,0,2" Delay="300" Interval="50"/>
                            </Grid>
                        </Grid>

                        <TextBlock Grid.Column="2" 
                                   Text="Ajuste de Limites" 
                                   Foreground="#505060" 
                                   FontSize="11" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>

                        <Grid Grid.Column="3" ToolTip="Temperatura maxima da escala visual" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource PropInputStyle}"
                                     Text="{Binding LevelMaxC, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                     HorizontalContentAlignment="Right"/>
                            <Grid Grid.Column="1" Margin="1,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <RepeatButton Grid.Row="0" Content="▲" Command="{Binding IncrementLevelMaxCommand}" FontSize="6" Padding="0" Background="#2A2A3E" Foreground="#C8C8D8" BorderThickness="0" Margin="0,2,0,1" Delay="300" Interval="50"/>
                                <RepeatButton Grid.Row="1" Content="▼" Command="{Binding DecrementLevelMaxCommand}" FontSize="6" Padding="0" Background="#2A2A3E" Foreground="#C8C8D8" BorderThickness="0" Margin="0,1,0,2" Delay="300" Interval="50"/>
                            </Grid>
                        </Grid>

                        <TextBlock Grid.Column="4"
                                   Foreground="#8888AA"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Text="{Binding CurrentScaleLabel}"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="4" Background="#2A2A42" HorizontalAlignment="Stretch"/>

            <!-- ── RIGHT PANEL: Properties ── -->
            <Border Grid.Column="4" Background="#1E1E30" BorderBrush="#2A2A42" BorderThickness="1,0,0,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#161626" Padding="10,8">
                        <TextBlock Text="PROPRIEDADES"
                                   Foreground="#FF6600" FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <TabControl DockPanel.Dock="Top"
                                Background="Transparent"
                                BorderBrush="#2A2A42"
                                Padding="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="#161626"/>
                                <Setter Property="Foreground" Value="#8888AA"/>
                                <Setter Property="BorderBrush" Value="#2A2A42"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1E1E30"/>
                                        <Setter Property="Foreground" Value="#FF6600"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Resources>

                        <!-- ── Tab: Termograma / Equipamento ── -->
                        <TabItem Header="Termograma">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E30">
                                <StackPanel Margin="10">

                                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="ARQUIVO"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Câmera"/>
                                    <TextBlock Text="{Binding SelectedThermogram.CameraModel}"
                                               Foreground="#D8D8E8" FontSize="12" Margin="0,2,0,6"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Data de Captura"/>
                                    <TextBlock Text="{Binding SelectedThermogram.CaptureAtUtc, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                               Foreground="#D8D8E8" FontSize="12" Margin="0,2,0,10"/>

                                    <Separator Background="#2A2A42" Margin="0,4,0,4"/>
                                    <Expander IsExpanded="False" Margin="0,0,0,4"
                                              Foreground="#FF6600" Background="Transparent"
                                              BorderBrush="Transparent" BorderThickness="0">
                                        <Expander.Header>
                                            <TextBlock Text="CÂMERA / CAPTURA"
                                                       Foreground="#FF6600" FontSize="11"
                                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                                       Margin="4,0,0,0"/>
                                        </Expander.Header>
                                        <StackPanel Margin="0,4,0,0">
                                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="N° de Série"/>
                                            <TextBlock Text="{Binding CameraSerialDisplay}"
                                                       Foreground="#D8D8E8" FontSize="12" Margin="0,2,0,6"/>

                                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Data/Hora EXIF"/>
                                            <TextBlock Text="{Binding CaptureDateTimeDisplay}"
                                                       Foreground="#D8D8E8" FontSize="11" TextWrapping="Wrap"
                                                       Margin="0,2,0,6"/>

                                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Campo de Visão (FOV)"/>
                                            <TextBlock Text="{Binding FieldOfViewDisplay}"
                                                       Foreground="#D8D8E8" FontSize="12" Margin="0,2,0,6"/>

                                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Janela IR (Temp. / Transmit.)"/>
                                            <TextBlock Text="{Binding IrWindowDisplay}"
                                                       Foreground="#D8D8E8" FontSize="12" Margin="0,2,0,6"/>
                                        </StackPanel>
                                    </Expander>

                                    <Separator Background="#2A2A42" Margin="0,4,0,4"/>
                                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="EQUIPAMENTO"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Tag / Código"/>
                                    <TextBox Style="{StaticResource PropInputStyle}"
                                             Text="{Binding ThermogramEquipmentTag, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Descrição"/>
                                    <TextBox Style="{StaticResource PropInputStyle}"
                                             Text="{Binding ThermogramEquipmentDescription, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Localização"/>
                                    <TextBox Style="{StaticResource PropInputStyle}"
                                             Text="{Binding ThermogramEquipmentLocation, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Style="{StaticResource PropLabelStyle}" Text="Criticidade"/>
                                    <ComboBox Style="{StaticResource PropComboStyle}"
                                              ItemsSource="{Binding CriticalityOptions}"
                                              SelectedItem="{Binding ThermogramCriticality}"
                                              Height="28">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource CriticalityToPortugueseConverter}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Separator Background="#2A2A42" Margin="0,8,0,4"/>
                                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="OBSERVAÇÕES"/>

                                    <TextBox Style="{StaticResource PropInputStyle}"
                                             Text="{Binding ThermogramNotes, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>

                                    <Button Content="Salvar Propriedades"
                                            Command="{Binding SaveThermogramPropertiesCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Margin="0,10,0,0" Height="30"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>


                        <!-- ── Tab: Medições ── -->
                        <TabItem Header="Medições">
                            <DockPanel Background="#1E1E30">
                                <TextBlock DockPanel.Dock="Top"
                                           Style="{StaticResource PanelHeaderStyle}"
                                           Margin="10,8,10,4" Text="MEDIÇÕES DO TERMOGRAMA"/>
                                <DataGrid ItemsSource="{Binding Measurements}"
                                          SelectedItem="{Binding SelectedMeasurement}"
                                          DockPanel.Dock="Top"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="False"
                                          Background="#1E1E30"
                                          RowBackground="#222235"
                                          AlternatingRowBackground="#1E1E30"
                                          Foreground="#C8C8D8"
                                          BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A2A42"
                                          FontSize="11"
                                          Margin="4,0">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#161626"/>
                                            <Setter Property="Foreground" Value="#8888AA"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="FontSize" Value="10"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="60" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Tmin" Binding="{Binding Tmin, StringFormat=F1}" Width="50" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Tmax" Binding="{Binding Tmax, StringFormat=F1}" Width="50" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Tavg" Binding="{Binding Tavg, StringFormat=F1}" Width="50" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="ΔT" Binding="{Binding DeltaT, StringFormat=F1}" Width="45" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Tmax adm." Binding="{Binding MaxAdmissibleC, StringFormat=F1}" Width="*" IsReadOnly="False"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="6,4,6,6">
                                    <Button Content="Remover Selecionada"
                                            Command="{Binding RemoveSelectedMeasurementCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Width="150" Height="28"/>
                                    <Button Content="Salvar Tmax adm."
                                            Command="{Binding SaveSelectedMeasurementTmaxCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Width="120" Height="28" Margin="8,0,0,0"
                                            ToolTip="Salva o Tmax admissível editado para o spot selecionado"/>
                                    <Button Content="Desfazer Ultima"
                                            Command="{Binding UndoLastActionCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Width="120" Height="28" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </TabItem>


                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             ROW 3 — STATUS BAR
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#111120" BorderBrush="#2A2A42" BorderThickness="0,1,0,0" Padding="10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Foreground="#404060" FontSize="10"
                           VerticalAlignment="Center" Text="Thermix Studio v2.0" Margin="0,0,6,0"/>
                <TextBlock Foreground="#8888AA" FontSize="11" VerticalAlignment="Center"
                           Text="{Binding StatusMessage}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
