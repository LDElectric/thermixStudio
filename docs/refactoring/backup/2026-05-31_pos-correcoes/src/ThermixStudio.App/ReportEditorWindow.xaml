<Window x:Class="ThermixStudio.App.ReportEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThermixStudio.App"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Editor de Relatório Termográfico"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        Foreground="#E6E6EF"
        MinWidth="1320"
        MinHeight="840">
    <Window.Resources>
        <local:FileNameValueConverter x:Key="FileNameConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#232336"/>
            <Setter Property="Foreground" Value="#E6E6EF"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E6E6EF"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF8833"/>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6600"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#161626"/>
            <Setter Property="BorderBrush" Value="#2A2A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="PreviewCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F4F6FA"/>
            <Setter Property="BorderBrush" Value="#D7DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E6E6EF"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C8C8D8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2A2A42"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3050"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222238"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" MinWidth="380"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E30" BorderBrush="#2A2A42" BorderThickness="1" CornerRadius="16" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Editor do relatório" FontSize="24" FontWeight="SemiBold" Foreground="#FF6600" Margin="0,0,0,4"/>
                    <TextBlock Text="Ambiente técnico para composição, revisão e emissão do relatório termográfico." Foreground="#B8BED6" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dados do relatório" Style="{StaticResource PanelTitleStyle}"/>

                            <TextBlock Text="Número da OS"/>
                            <TextBox Text="{Binding OsNumber, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Instalação"/>
                            <TextBox Text="{Binding InstallationName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Equipamento"/>
                            <TextBox Text="{Binding EquipmentName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Termografista / Relatado por"/>
                            <TextBox Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nº Certificação" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding CertificationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Data" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding ReportDate, UpdateSourceTrigger=PropertyChanged}"
                                                Background="#FFFFFF" Foreground="#1F2430" BorderBrush="#C0C7D9">
                                        <DatePicker.Resources>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                <Setter Property="Foreground" Value="#1F2430"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="#C0C7D9"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                            </Style>
                                        </DatePicker.Resources>
                                    </DatePicker>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Biblioteca de termogramas" Style="{StaticResource PanelTitleStyle}"/>
                            <ListBox ItemsSource="{Binding AvailableThermograms}"
                                     SelectedItem="{Binding SelectedAvailableThermogram}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding FilePath, Converter={StaticResource FileNameConverter}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding CaptureAtUtc, StringFormat={}{0:dd/MM/yy HH:mm}}"
                                                           FontSize="10" Foreground="#7E859D"/>
                                                <TextBlock Text=" | " FontSize="10" Foreground="#4F556A"/>
                                                <TextBlock Text="{Binding EquipmentTag}"
                                                           FontSize="10" Foreground="#FF8844"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Content="Adicionar ao relatório"
                                    Command="{Binding AddSelectedThermogramCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Seções editáveis" Style="{StaticResource PanelTitleStyle}"/>
                            <ListBox ItemsSource="{Binding Sections}"
                                     SelectedItem="{Binding SelectedSection}"
                                     MaxHeight="290">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2A2A42" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,8" Background="#171724">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ThermogramLabel}" FontSize="10.5" Foreground="#AAB" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding MeasurementsLabel}" FontSize="10.5" Foreground="#FF8844"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Content="Remover seção selecionada"
                                    Command="{Binding RemoveSelectedSectionCommand}"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Observações e recomendações por termograma" Style="{StaticResource PanelTitleStyle}"/>

                            <ItemsControl ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="True"
                                                  Margin="0,0,0,8"
                                                  Background="#171724"
                                                  BorderBrush="#2A2A42"
                                                  BorderThickness="1"
                                                  Foreground="#E6E6EF"
                                                  Padding="8">
                                            <Expander.Header>
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF8844"
                                                           Text="{Binding Title, StringFormat=OBSERVAÇÕES E RECOMENDAÇÕES {0}}"/>
                                            </Expander.Header>

                                            <StackPanel Margin="0,8,0,0">
                                                <TextBlock Text="Observações:" Foreground="#8888AA" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding Observations, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" Height="70" TextWrapping="Wrap"/>

                                                <TextBlock Text="Ação Recomendada:" Foreground="#8888AA" FontSize="11" Margin="0,4,0,4"/>
                                                <TextBox Text="{Binding Recommendation, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" Height="70" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
                        <Button Content="Baixar PDF"
                            Click="DownloadPdfButton_Click"
                            MinWidth="132"/>
                        <Button Content="Gerar Relatório"
                                Click="GenerateReportButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="132"/>
                        <Button Content="Cancelar"
                                Command="{Binding CancelCommand}"
                                MinWidth="96"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="Transparent"/>

        <Border Grid.Column="2" Style="{StaticResource PreviewCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="6,4,6,12">
                    <TextBlock Text="Pré-visualização do relatório" FontSize="22" FontWeight="SemiBold" Foreground="#1F2430"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D8DEEA" BorderThickness="1" CornerRadius="12" Padding="10">
                    <wv2:WebView2 x:Name="PreviewBrowser"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
